# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Convex (Phase 1): dashboard > deployment settings
# Client URL of the production deployment (safe to expose to the browser).
NEXT_PUBLIC_CONVEX_URL=https://patient-ox-888.convex.cloud
# Deploy key for pushing functions from CI or local (server-only, never expose).
CONVEX_DEPLOY_KEY=

# Hold TTL in seconds (Phase 2). Short value in test environments keeps TTL behavior testable.
HOLD_TTL_SECONDS=600

# Shared secret guarding POST /api/internal/expire-holds (sent as the x-internal-key
# header by the TTL tests). Leave empty to disable the endpoint. Set a long random value.
INTERNAL_TASK_KEY=
