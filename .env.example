# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Supabase (Phase 1): project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used by seed scripts and privileged route handlers. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Hold TTL in seconds (Phase 2). Short value in test environments keeps TTL behavior testable.
HOLD_TTL_SECONDS=600
